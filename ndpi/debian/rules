#!/usr/bin/make -f
# Packaging for the nDPI xt_ndpi netfilter stack:
#   xt-ndpi-dkms      - kernel module source, built per-kernel by DKMS
#   xt-ndpi-iptables  - libxt_ndpi.so userspace "-m ndpi" iptables extension
#   xt-ndpi-filter     - configurable systemd rule engine (/usr/sbin/ndpi-filter)

export DH_VERBOSE = 1

DKMS_NAME = xt-ndpi
DKMS_VER  = $(shell dpkg-parsechangelog -SVersion)

CURDIR ?= $(shell pwd)
SRCDST    = $(CURDIR)/debian/xt-ndpi-dkms/usr/src/$(DKMS_NAME)-$(DKMS_VER)
IPTDST    = $(CURDIR)/debian/xt-ndpi-iptables
RULESDST  = $(CURDIR)/debian/xt-ndpi-filter

%:
	dh $@ --with dkms

# Run upstream configure ONCE here (build host) to generate the arch-neutral
# headers (ndpi_config.h, ndpi_define.h) needed by both the module source and
# the iptables extension. --with-only-libndpi keeps it lean (no
# libpcap/flex/bison; bundled gcrypt-light). For the DKMS package this lets us
# ship a tiny pre-configured source subset and skip autotools on the target.
override_dh_auto_configure:
	./configure --with-only-libndpi

# Build only the userspace iptables extension (libxt_ndpi.so) for the
# xt-ndpi-iptables package. The kernel module is NOT built here — DKMS builds
# it on the target.
override_dh_auto_build:
	$(MAKE) -C ndpi-netfilter/ipt

override_dh_auto_test:

# Two install targets:
#  - xt-ndpi-dkms: stage ONLY what the kernel module build needs (src/ +
#    ndpi-netfilter/), dropping ~400MB of tests/fuzz/dga/doc data. Done in the
#    install phase (after dh_prep wipes debian/<pkg>). '*.so' is excluded so the
#    libxt_ndpi.so just built by dh_auto_build doesn't leak into the source.
#  - xt-ndpi-iptables: install libxt_ndpi.so (+ libxt_NDPI.so symlink) into the
#    arch xtables plugin dir via the upstream Makefile.
override_dh_auto_install:
	mkdir -p $(SRCDST)
	rsync -a \
	  --exclude='*.o' --exclude='*.ko' --exclude='*.so' \
	  --exclude='*.cmd' --exclude='.*.cmd' \
	  --exclude='*.mod' --exclude='*.mod.c' \
	  --exclude='Module.symvers' --exclude='modules.order' \
	  --exclude='windows' --exclude='*~' \
	  src ndpi-netfilter $(SRCDST)/
	$(MAKE) -C ndpi-netfilter/ipt install DESTDIR=$(IPTDST)
	# xt-ndpi-filter: the generic rule engine + module autoload entry.
	install -D -m0755 debian/ndpi-filter $(RULESDST)/usr/sbin/ndpi-filter
	install -D -m0644 debian/xt_ndpi-modules-load.conf \
	  $(RULESDST)/usr/lib/modules-load.d/xt_ndpi.conf

# Install + enable ndpi-filter.service (from xt-ndpi-filter.ndpi-filter.service).
override_dh_installsystemd:
	dh_installsystemd --name=ndpi-filter --no-stop-on-upgrade

# Stamp the DKMS source version to match this package version.
override_dh_dkms:
	dh_dkms -V $(DKMS_VER)