# Common host for AmneziaWG (awg-easy) and WireGuard (wg-easy)
WG_HOST=1.2.3.4

# AmneziaWG (awg-easy)
# Generate hash: docker run --rm ghcr.io/w0rng/amnezia-wg-easy wgpw 'your-password'
AWG_PASSWORD_HASH=
# AWG_PORT=51820
# AWG_DEFAULT_DNS=1.1.1.1
# AWG_DEFAULT_ADDRESS=10.0.0.x
# AWG_ALLOWED_IPS=0.0.0.0/0, ::/0
# AWG_PERSISTENT_KEEPALIVE=25

# WireGuard (wg-easy)
# WG_PORT=51830

# Multi-IP exit routing (shared by both services)
# Format: "gateway:external_ip,gateway:external_ip,..."
# Tables are auto-assigned: 100, 101, 102...
EXIT_ROUTES=172.100.0.1:1.2.3.4,172.101.0.1:2.3.4.5
